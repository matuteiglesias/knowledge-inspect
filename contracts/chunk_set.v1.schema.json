{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kb/contracts/chunk_set.v1.schema.json",
  "title": "chunk_set.v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "artifact_family",
    "artifact_kind",
    "schema_version",
    "run_id",
    "producer",
    "entrypoint",
    "source_items",
    "chunk_count",
    "chunks"
  ],
  "properties": {
    "artifact_family": {"const": "chunk_bus"},
    "artifact_kind": {"const": "chunk_set"},
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "producer": {"type": "string", "minLength": 1},
    "entrypoint": {"type": "string", "minLength": 1},
    "source_items": {
      "type": "array",
      "items": {"type": "string"}
    },
    "chunk_count": {"type": "integer", "minimum": 0},
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["chunk_id", "text", "chunk_index", "char_len", "metadata"],
        "properties": {
          "chunk_id": {"type": "string", "minLength": 1},
          "text": {"type": "string"},
          "chunk_index": {"type": "integer", "minimum": 0},
          "char_len": {"type": "integer", "minimum": 0},
          "metadata": {"type": "object"},
          "paper_id": {"type": "string", "minLength": 1},
          "document_id": {"type": "string", "minLength": 1},
          "source_file": {"type": "string", "minLength": 1},
          "header_path": {
            "oneOf": [
              {"type": "string", "minLength": 1},
              {
                "type": "array",
                "items": {"type": "string"}
              }
            ]
          }
        }
      }
    }
  }
}
